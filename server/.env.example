# 复制为 .env 后按实际填写

# 监听端口（由 nginx 反向代理到 https）
PORT=4000
HOST=127.0.0.1

# 对外访问基础地址，用于拼接学校填表链接。务必是学校能访问到的 https 地址
PUBLIC_BASE_URL=https://jyj.yunbg.vip/collect

# 桌面端拉取 / 推送名单用的接口令牌（长随机串，勿泄露给学校）
API_TOKEN=changeme-api-token

# 管理看板登录令牌（催报用，只发给经办人）
ADMIN_TOKEN=changeme-admin-token

# 数据库文件路径（默认 server/data/collect.db）
# DB_PATH=/var/lib/gznb-collect/collect.db

# 备份目录（默认为数据库同级的 backups/ 目录）
# BACKUP_DIR=/var/lib/gznb-collect/backups

# DEFAULT_YEAR 已弃用：采集年度由系统自动按“当前年份 − 1”计算，无需也无法手动配置
